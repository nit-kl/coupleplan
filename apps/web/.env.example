# ビルド時に Vite へ埋め込まれる。Cloudflare Pages の Environment variables に同キーで設定。
# 例: Staging Worker の URL（末尾スラッシュなし）
# VITE_API_BASE_URL=https://coupleplan-api-staging.xxx.workers.dev

VITE_API_BASE_URL=http://127.0.0.1:8787

# Optional: Plausible Analytics（カスタムイベント名は funnel.ts の FunnelEvent と一致）
# VITE_PLAUSIBLE_DOMAIN=coupleplan.com
